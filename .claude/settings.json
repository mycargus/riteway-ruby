{
  "permissions": {
    "allow": [
      "Bash(bundle exec:*)",
      "WebFetch(domain:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-publish.sh"
          }
        ]
      }
    ]
  }
}
